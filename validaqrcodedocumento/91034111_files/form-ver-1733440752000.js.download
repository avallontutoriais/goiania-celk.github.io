function openJpegBase64(base64) {
const win = window.open("","_blank");
let html = '';
html += '<html>';
html += '<body style="margin:0!important">';
html += '<embed width="100%" height="100%" src="data:image/jpeg;base64,'+base64+'" type="image/jpeg" />';
html += '</body>';
html += '</html>';
setTimeout(() => {
win.document.write(html);
}, 0);
}
function openJpegBase64NewWindow(base64) {
if (base64.includes("data:image/jpeg;base64,")) {
base64 = base64.replace("data:image/jpeg;base64,", "");
}
const win = window.open("","_blank");
let html = '';
html += '<html>';
html += '<body style="margin:0!important">';
html += '<img src="data:image/jpeg;base64,'+base64+'" />';
html += '</body>';
html += '</html>';
setTimeout(() => {
win.document.write(html);
}, 0);
}
function moveControlsWindow(selector) {
selector = selector == null ? $('div.wicket-modal') : $(selector);
selector.each(function () {
var content = $(this).find('div.w_content_3');
if ($(this).find('div#control-bottom').length > 1) {
content.find('div.old-controls').remove();
}
var controlBottom = $(this).find('div#control-bottom');
if (controlBottom.length == 1 && !controlBottom.hasClass('old-controls')) {
controlBottom.appendTo($(this).find('div.w_content_3'));
controlBottom.addClass('old-controls');
}
});
}
function initDirtyForms(selector) {
selector = selector == null ? $('body') : $(selector);
$.DirtyForms.message = 'A página atual contém alterações não salvas que serão perdidas se você sair.';
$('form.dirty').dirtyForms();






}
function initReportNotification() {
$('.bubble-menu ul li a').click(function () {
$('.bubble-sub-menu').toggle();
});
$(document).bind('click', function (e) {
var $clicked = $(e.target);
if (!$clicked.parents().hasClass('bubble-menu'))
$('.bubble-sub-menu').hide();
});
}
function initPrintElement(selector) {
selector.delegate('a.print-fieldset', 'click', function (e) {
e.preventDefault();
var el = $(this).closest('fieldset');
if (!el.length)
el = $(this).parent().parent();
el = el.clone();
el.find('a').removeAttr('href').removeAttr('onclick');
el.find('thead').eq(0).find('th').append('<a class="print-remove-column">&times;</a>');
el.find('.dataTables_scroll').each(function () {
var table = Array();
$(this).find('tr').each(function (c) {
if (c == 0) {
table.push('<table><thead><tr>' + $(this).html() + '</tr></thead>\n<tbody>');
} else {
table.push('<tr>' + $(this).html() + '</tr>\n');
}
});
$(this).html(table.join('\n') + '</tbody></table>');
});
el.printElement({
printMode: 'popup',
leaveOpen: true,
overrideElementCSS: [
{
href: URL_PRINT_CSS,
media: 'all'
}
],
printBodyOptions:
{
styleToAdd: ''
}
});
});
}
function checkBrowser() {
if ($.browser.mozilla || $.browser.chrome || $.browser.webkit) {
let versionMajorEnd = $.browser.version.indexOf('.');
if(versionMajorEnd === -1){
versionMajorEnd = $.browser.version.length;
}
version = $.browser.version.substring(0, versionMajorEnd);
if ($.browser.mozilla && version < 19) {
bloquearAplicacao(true);
}
if ($.browser.chrome && version < 21) {
bloquearAplicacao(true);
}
} else {
bloquearAplicacao(false);
}
}
function bloquearAplicacao(desatualizado) {
$('fieldset').hide();
$('#warning-browser').show();
if (desatualizado) {
$('#navegadorIncompativel').hide();
} else {
$('#navegadorDesatualizado').hide();
}
}
function bookmarksSortable() {
$('header #bookmarks > span').click(function (e) {
$('header #bookmarks').toggleClass('active');
$('body').toggleClass('open-bookmark');
});
$('html').click(function (e) {
if ($('body').hasClass('open-bookmark') && $(e.target).closest('#bookmarks').length == 0) {
$('header #bookmarks').removeClass('active');
$('body').removeClass('open-bookmark');
}
});

}
function bubbleReports() {
$('header .bubble-reports > a').click(function (e) {
$('header .bubble-reports').toggleClass('active');
$('body').toggleClass('open-bubble-reports');
});
$('html').click(function (e) {
if ($('body').hasClass('open-bubble-reports') && $(e.target).closest('.bubble-reports').length == 0) {
$('header .bubble-reports').removeClass('active');
$('body').removeClass('open-bubble-reports');
}
});
}
function bubbleMessaging() {
$('header .bubble-messaging > a').click(function (e) {
$('header .bubble-messaging').toggleClass('active');
$('body').toggleClass('open-bubble-messaging');
});
$('html').click(function (e) {
if ($('body').hasClass('open-bubble-messaging') && $(e.target).closest('.bubble-messaging').length == 0) {
$('header .bubble-messaging').removeClass('active');
$('body').removeClass('open-bubble-messaging');
}
});
}
function bubbleHistoricoProntuario() {
$('.bubble-historico > a').click(function (e) {
$('.bubble-historico').toggleClass('active');
$('body').toggleClass('open-bubble-historico');
});
$('html').click(function (e) {
if ($('body').hasClass('open-bubble-historico') && $(e.target).closest('.bubble-historico').length == 0) {
$('.bubble-historico').removeClass('active');
$('body').removeClass('open-bubble-historico');
}
});
}
function bloqueiaEmojis() {
$('body').click(function(e) {
retiraEmojisInput();
});
$('body').keydown(function(e) {
retiraEmojisInput();
});
}
function retiraEmojisInput() {
$('input').keydown(function(e) {
var str = $(this).val();
str = str.replace(/([\u2700-\u27BF]|[\uE000-\uF8FF]|\uD83C[\uDC00-\uDFFF]|\uD83D[\uDC00-\uDFFF]|[\u2011-\u26FF]|\uD83E[\uDD10-\uDDFF]|[\u0250-\ue007])/g, '');
$(this).val(str);
}
);
$('input').change(function(e) {
var str = $(this).val();
str = str.replace(/([\u2700-\u27BF]|[\uE000-\uF8FF]|\uD83C[\uDC00-\uDFFF]|\uD83D[\uDC00-\uDFFF]|[\u2011-\u26FF]|\uD83E[\uDD10-\uDDFF]|[\u0250-\ue007])/g, '');
$(this).val(str);
}
);
}
function seachProgramas() {
$('a.busca-programas').click(function () {
var link = $(this);
show_search_programas(link);
});
$('html').click(function (e) {
if ($('body').hasClass('open-busca-programas') && $(e.target).closest('div.busca-programas').length == 0) {
hide_search_programas();
}
});
$.Shortcuts.add({
type: 'down',
mask: 'Ctrl+O',
enableInInput: true,
handler: function () {
show_search_programas($('a.busca-programas'));
}
}).start();
}
function show_search_programas(link) {
if ($('body').hasClass('open-busca-programas')) {
hide_search_programas();
} else {
link.closest('div.busca-programas').animate({right: '0px'}, 'fast', function () {
link.closest('div.busca-programas').find('li.token-input-input-token-celk input').focus();
});
link.addClass('active');
$('body').toggleClass('open-busca-programas');
}
}
function hide_search_programas() {
var link = $('a.busca-programas');
link.removeClass('active');
link.closest('div.busca-programas').animate({right: '-416px'}, 'fast');
$('body').removeClass('open-busca-programas');
link.closest('div.busca-programas').find('li.token-input-input-token-celk input').blur();
}
(function ($) {
$.fn.noCapslock = function () {
$(this).keypress(function (e) {
var $this = $(this);
var $next;
var s = String.fromCharCode(e.which);
if ($this.next().is('div.warning.in-input')) {
$next = $this.next();
} else {
$next = $('<div class="warning in-input"></label>').insertAfter($this);
}
if (s.toUpperCase() === s && s.toLowerCase() !== s && !e.shiftKey) {
$next.show().text('Caps Lock ativo.');
} else {
$next.hide();
}
});
};
})(jQuery);
function toggleFieldset(fieldsetId) {
var toggle = $('#' + fieldsetId);
$('> div.expand', toggle).slideToggle('fast', function () {
resizeDataTable($(this));
});
var link = $('> h2 > a.expand', toggle);
link.text(link.text() == link.data('recolher') ? link.data('expandir') : link.data('recolher'));
link.toggleClass('opened');
}
function showFieldset(fieldsetId) {
var toggle = $('#' + fieldsetId);
$('> div.expand', toggle).show('fast', function () {
resizeDataTable($(this));
});
var link = $('> h2 > a.expand', toggle);
link.text(link.data('recolher'));
link.addClass('opened');
}
function hideFieldset(fieldsetId) {
var toggle = $('#' + fieldsetId);
$('> div.expand', toggle).hide('fast', function () {
resizeDataTable($(this));
});
var link = $('> h2 > a.expand', toggle);
link.text(link.data('expandir'));
link.removeClass('opened');
}
function focusComponent(componentId) {
componentId.focus();
componentId.select();
}
function removeAutoCompleteDrop() {
$('.token-input-dropdown-celk').css('display', 'none');
$('.token-input-dropdown-celk-required').css('display', 'none');
}
function onEnterPressed(buttonId, evt) {
var key = (evt.which) ? evt.which : evt.keyCode;
if (key === 13) {
document.getElementById(buttonId).focus();
document.getElementById(buttonId).click();
}
}