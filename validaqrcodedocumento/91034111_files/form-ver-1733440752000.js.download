var html, header, section, sidebar;
$(document).ready(function () {
checkBrowser();
html = $('html');
header = $('header');
section = $('section');
sidebar = $('nav#sidebar');
resizeSidebar();
$(window).resize(function () {
resizeSidebar();
resizeTable();
});
themeUI();
bookmarksSortable();
bubbleReports();
bubbleMessaging();
bubbleHistoricoProntuario();
seachProgramas();
bloqueiaEmojis();
$('form.dirty').dirtyForms('setClean');
resizeReportView();
});

function resizeSidebar() {
if (sidebar.length) {
if (section.hasClass('section-atendimento')) {
section.width(html.width() - sidebar.width() - 40);
} else {
section.width(html.width() - sidebar.width() - 45);
}
var he = sidebar.height('').height();
if (section.height() > he) {
sidebar.height(section.height());
}
}
}
function resizeReportView() {
var filtrosRelatorio = $('div#filtros-relatorio');
var reportPanel = $('div.report-panel .egg-container');
if (filtrosRelatorio.height() > 200) {
reportPanel.css('height', filtrosRelatorio.height() - 53);
}
}
function themeUI(selector) {
selector = selector == null ? $('body') : $(selector);
selector.delegate('.warning .close', 'click', function () {
$(this).closest('.warning').fadeOut();
});
selector.find('ul.treeview').treeview({
animated: "fast",
collapsed: true
});









$(selector).delegate('a.expand', 'click', function () {
var toggle = $(this);
do {
toggle = toggle.parent().closest('fieldset');
} while (toggle.length != 0 && toggle.find('div.expand').slideToggle('fast', function () {
resizeDataTable($(this));
}).length == 0);
$(this).text($(this).text() == $(this).data('recolher') ? $(this).data('expandir') : $(this).data('recolher'));
$(this).toggleClass('opened');
});
$(selector).delegate('a.expand-fieldset', 'click', function () {
$(this).parent().closest('fieldset').find('div.field').slideToggle();
$(this).text($(this).text() == '[+] Expandir' ? '[-] Recolher' : '[+] Expandir');
});
$(selector).delegate('li.modulo', 'mouseover', function () {
var modulo = $(this);
$(selector).find('li.modulo.active').removeClass('active');
modulo.addClass('active');
});
initExpandLinks(selector);

initTextAreaLimit(selector);
initMasks(selector);
initDirtyForms(selector);
initReportNotification();
initPrintElement(selector);
}

function loading(modal) {
var elCarregando = $('#carregando').length ? $('#carregando') : $('<div id="carregando" class="warning"><span>Carregando</span></div>').prependTo('body');
elCarregando.show();
var elCarregandoModal = $('#carregando-modal').length ? $('#carregando-modal') : $('<div id="carregando-modal" class="ui-widget-overlay" />').prependTo('body');
if (modal) {
elCarregandoModal.show();
} else {
elCarregandoModal.hide();
}
}

function stopLoading() {
$('#carregando').hide();
$('#carregando-modal').hide();
}

function resizeTable() {
$('.scroll-width-table').each(function () {
$(this).hide().width($(this).parent().width() - parseInt($(this).parent().css('padding-left'), 10)).show();
});
}
function resizeDataTable($el) {
$el.find('.dataTables_scrollBody .dataTable').each(function () {
if ($(this).DataTable) {
$(this).DataTable().fnAdjustColumnSizing()
}
});
}
function removeEnterSubmitFromForm(selector) {
selector = selector == null ? $('body') : $(selector);
selector.find('form').keydown(function (ev) {
if (ev.which == 13 && ev.target.nodeName != 'TEXTAREA')
ev.preventDefault();
});
}
function initMasks(selector) {
selector = selector == null ? $('body') : $(selector);

selector.find('input.date').mask('99/99/9999');
selector.find('input.mesAno').mask('99/9999');
selector.find('input.processoArquitetonico').mask('999999/9999');
selector.find('input.inscricaoImobiliaria').mask('99.99.999.9999.999-999');
selector.find('input.diaMes').mask('99/99');
selector.find('input.cpf').mask('999.999.999-99');
selector.find('input.cns').mask('999.9999.9999.9999');
selector.find('input.fone').mask('(99) 99999-999?9');
selector.find('input.cep').mask('99999-999');
selector.find('input.hora').mask('99:99');
selector.find('input.date-hora').mask('99/99/9999 - 99:99');
selector.find('input.placa').mask('aaa-9999');
selector.find('input.placaNova').mask('*******');
selector.find('input.numeroVigilancia').mask('9999');
selector.find('input.uf').mask('aa');
selector.find('input.ddd').mask('99');
selector.find('input.chassi').mask('*****************');
selector.find('input.renavam').mask('999999999');
selector.find('input.matriculaCertidao').mask('999999.99.99.9999.9.99999.999.9999999.99');
selector.find('input.cnpj').mask('99.999.999/9999-99');
selector.find('input.chaveGuiaProcedimentos').mask('99999.9?99999999');
selector.find('input.telefoneFixo').mask('(99) 9999-9999?9');
selector.find('input.unidadeOrcamentaria').mask('999.999.999.999.999');
selector.find('input.rassVersao').mask('99.99');
selector.find('input.moeda').keyup(function (ev) {
$(this).val($(this).val().replace(/[^\.\,\d]/g, ''));
});
selector.find('input.number').keyup(function (ev) {
$(this).val($(this).val().replace(/\D/g, ''));
});
selector.find('input.alfanumber').keyup(function (ev) {
$(this).val($(this).val().replace(/\W/g, ''));
});
selector.find('input.company-name').keyup(function (ev) {
$(this).val($(this).val().replace(/[^a-zA-Z0-9À-ÖØ-öø-ÿ'\s]+/g, ''));
});
selector.find('input.names').keyup(function (ev) {
$(this).val($(this).val().replace(/[^A-Za-zÀ-ÖØ-öø-ÿ'\s]/g, ""));
});
selector.find('textarea.removeEnter').keyup(function(ev) {
$(this).val($(this).val().replace("\n", ""));
});
}
function initExpandLinks(selector) {
selector = selector == null ? $('body') : $(selector);
$(selector).find('a.expand').each(function () {
$(this).text($(this).data('expandir'));
});
$(selector).find('a.expand.opened').each(function () {
$(this).text($(this).data('recolher'));
});
}
function initPrevNextFieldset(selector) {
selector = selector == null ? $('body') : $(selector);
$(selector).find('fieldset.prev-next').each(function () {
$(this).find("h2>label").wrap("<a class=\"expand-link\"></a>");
if ($(this).hasClass("first")) {
$("<label class=\"expand-label\">[-] </label>").prependTo($(this).find("h2>a.expand-link"));
$("<div class=\"field\"><div class=\"span-horizontal\"><a class=\"next-link\">Próximo &gt; </a></div></div>").appendTo(this);
} else if ($(this).hasClass("last")) {
$("<label class=\"expand-label\">[+] </label>").prependTo($(this).find("h2>a.expand-link"));
$("<div class=\"field\"><div class=\"span-horizontal\"><a class=\"prev-link\">&lt; Anterior</a></div></div>").appendTo(this);
} else {
$("<label class=\"expand-label\">[+] </label>").prependTo($(this).find("h2>a.expand-link"));
$("<div class=\"field\"><div class=\"span-horizontal\"><a class=\"prev-link\">&lt; Anterior</a> | <a class=\"next-link\">Próximo &gt; </a></div></div>").appendTo(this);
}
});
$(selector).undelegate('a.next-link', 'click');
$(selector).undelegate('a.prev-link', 'click');
$(selector).undelegate('a.expand-link', 'click');
$(selector).delegate('a.next-link', 'click', function () {
var hideElements = $(this).parent().closest('fieldset').find('div.field');
var containerHide = $(this).parent().closest('fieldset').closest('.field');
var next = $(this).parent().closest('fieldset').closest('.field').nextAll(":has(.prev-next):first");
var count = 1;
hideElements.hide('fast', function () {
if (count === hideElements.length) {
resolveExpandLabel(containerHide);
openPrevNextFieldset(next);
}
count++;
});
});
$(selector).delegate('a.prev-link', 'click', function () {
var hideElements = $(this).parent().closest('fieldset').find('div.field');
var containerHide = $(this).parent().closest('fieldset').closest('.field');
var count = 1;
hideElements.hide('fast', function () {
if (count === hideElements.length) {
resolveExpandLabel(containerHide);
}
count++;
});
resolveExpandLabel($(this).parent().closest('fieldset').closest('.field'));
var prev = $(this).parent().closest('fieldset').closest('.field').prevAll(":has(.prev-next):first");
openPrevNextFieldset(prev);
});
$(selector).delegate('a.expand-link', 'click', function () {
var target = $(this).parent().closest('fieldset').closest('.field');













togglePrevNextFieldset(target);

});
}
function resolveExpandLabel(containerRow) {
var expandLabel = containerRow.find('label.expand-label');
var visibleElements = containerRow.find('div.field:visible');
expandLabel.text(visibleElements.length === 0 ? '[+] ' : '[-] ');
}
function togglePrevNextFieldset(containerRow) {
var toggleElements = containerRow.find('div.field');
var count = 1;
toggleElements.slideToggle('fast', function () {
resizeDataTable($(this));
initTextAreaLimit($(this));
if (count === toggleElements.length) {
resolveExpandLabel(containerRow);
}
count++;
});
containerRow.scrollTo();
}
function openPrevNextFieldset(containerRow) {
containerRow.find('div.field').show('fast', function () {
resizeDataTable($(this));
initTextAreaLimit($(this));
});
resolveExpandLabel(containerRow);
containerRow.scrollTo();
}
(function ($) {
$.fn.scrollTo = function () {
$('html, body').animate({
scrollTop: $(this).offset().top + 'px'
}, 'fast');

return this; 
}
})(jQuery);
function initTextAreaLimit(selector) {
selector = selector == null ? $('body') : $(selector);
selector.find('textarea.limit').each(function () {
var textarea = $(this);
if (!textarea.parent().hasClass("limit")) {
var span = textarea.wrap('<span class="texarea limit" />').parent();
var limit = textarea.data('limit') - $(this).val().length;
span.append('<span>' + limit + '</span>');
textarea.keyup(function() {
refreshTextAreaLimit($(this));
});
}
});
}
function resetTextAreaLimit(selector) {
selector = selector == null ? $('body') : $(selector);
if (selector.is('textarea.limit'))
selector = selector.parent();
selector.find('textarea.limit').each(function () {
var textarea = $(this);
if (textarea.hasClass("limit")) {
var span = textarea.closest('span[class=texarea limit]');
span.find('span').remove();
var limit = textarea.data('limit') - $(this).val().length;
span.append('<span>' + limit + '</span>');
textarea.keyup(function() {
refreshTextAreaLimit($(this));
});
}
});
}
function refreshTextAreaLimit(textArea) {
var restantes = $(textArea).data('limit') - $(textArea).val().length;
if (restantes < 0) {
restantes = 0;
$(textArea).val(textArea.val().substring(0, $(textArea).data('limit')));
}
$(textArea).next().text(restantes);
}
function openDownloadPdfBase64(base64) {
const str = `data:application/pdf;base64,${base64}`;
setTimeout(() => {
window.open(str,"_blank");
}, 0);
}
function openPdfBase64(base64) {
const str = `data:application/pdf;base64,${base64}`;
let html = '';
html += '<html>';
html += '<body style="height:100vh;margin:0!important;">';
html += '<iframe width="100%" height="100%" src="' + str + '"></iframe>';
html += '</body>';
html += '</html>';
setTimeout(() => {
const win = window.open("","_blank");
win.document.write(html);
}, 0);
}
